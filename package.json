    "@eslint/js": "^9.39.1",
    "@react-email/components": "^1.0.8",
    "@react-email/preview-server": "5.2.9",
    "@react-email/render": "^2.0.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "^3.8.1",
    "pretty-quick": "4.2.2",
