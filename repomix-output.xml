    last_page: number
    per_page: number
    to: number | null
    total: number
    path?: string
    first_page_url?: string
    last_page_url?: string
    next_page_url?: string | null
    prev_page_url?: string | null
}

// Pagination state
export interface IPagination {
    page: number
    limit: number
    total: number
    pages: number
    per_page: number
    to?: number | null
    from?: number | null
}
